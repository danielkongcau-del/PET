{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pet.local/schemas/v1/pet-motion.schema.json",
  "title": "PET Motion Protocol v1 message",
  "description": "One complete object is encoded on each UTF-8 NDJSON line.",
  "type": "object",
  "additionalProperties": false,
  "required": ["protocol", "version", "type", "seq", "timestamp_ms", "payload"],
  "properties": {
    "protocol": { "const": "pet-motion" },
    "version": { "const": 1 },
    "type": {
      "enum": [
        "hello",
        "ready",
        "world_state",
        "horizon_plan",
        "cancel",
        "ping",
        "pong",
        "metrics",
        "error"
      ]
    },
    "seq": { "$ref": "#/$defs/nonNegativeSafeInteger" },
    "timestamp_ms": { "$ref": "#/$defs/nonNegativeSafeInteger" },
    "payload": { "type": "object" }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "hello" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/helloPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "ready" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/readyPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "world_state" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/worldStatePayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "horizon_plan" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/horizonPlanPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "cancel" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/cancelPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "ping" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/pingPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "pong" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/pongPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "metrics" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/metricsPayload" } } }
    },
    {
      "if": { "properties": { "type": { "const": "error" } }, "required": ["type"] },
      "then": { "properties": { "payload": { "$ref": "#/$defs/errorPayload" } } }
    }
  ],
  "$defs": {
    "vec3": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": { "type": "number" }
    },
    "quat": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": { "type": "number", "minimum": -1, "maximum": 1 }
    },
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "nonNegativeSafeInteger": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "rect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "minimum": 0 },
        "height": { "type": "number", "minimum": 0 }
      }
    },
    "runtimeInfo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "pid"],
      "properties": {
        "name": { "$ref": "#/$defs/identifier" },
        "version": { "type": "string", "minLength": 1, "maxLength": 64 },
        "pid": { "$ref": "#/$defs/nonNegativeSafeInteger" },
        "python_version": { "type": "string", "maxLength": 64 },
        "torch_version": { "type": "string", "maxLength": 64 },
        "device": { "type": "string", "maxLength": 128 },
        "skeleton_sha256": { "type": "string", "minLength": 64, "maxLength": 64 }
      }
    },
    "privacyConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": ["screen_capture_enabled", "keyboard_enabled", "recording_enabled"],
      "properties": {
        "screen_capture_enabled": { "type": "boolean" },
        "keyboard_enabled": { "type": "boolean" },
        "recording_enabled": { "type": "boolean" }
      }
    },
    "helloConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "world_state_hz",
        "plan_horizon_ms",
        "plan_dt_ms",
        "pet_width",
        "pet_height",
        "privacy"
      ],
      "properties": {
        "world_state_hz": { "type": "number", "exclusiveMinimum": 0, "maximum": 240 },
        "plan_horizon_ms": { "type": "integer", "minimum": 50, "maximum": 5000 },
        "plan_dt_ms": { "type": "integer", "minimum": 8, "maximum": 250 },
        "pet_width": { "type": "number", "exclusiveMinimum": 0 },
        "pet_height": { "type": "number", "exclusiveMinimum": 0 },
        "privacy": { "$ref": "#/$defs/privacyConfig" }
      }
    },
    "helloPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "host", "requested_version", "capabilities", "config"],
      "properties": {
        "session_id": { "$ref": "#/$defs/identifier" },
        "host": { "$ref": "#/$defs/runtimeInfo" },
        "requested_version": { "const": 1 },
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "config": { "$ref": "#/$defs/helloConfig" }
      }
    },
    "readyPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "generator", "accepted_version", "capabilities", "ready_at_ms"],
      "properties": {
        "session_id": { "$ref": "#/$defs/identifier" },
        "generator": { "$ref": "#/$defs/runtimeInfo" },
        "accepted_version": { "const": 1 },
        "capabilities": {
          "type": "array",
          "items": { "$ref": "#/$defs/identifier" },
          "uniqueItems": true
        },
        "ready_at_ms": { "$ref": "#/$defs/nonNegativeSafeInteger" }
      }
    },
    "displayState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "bounds", "work_area", "scale_factor", "is_primary"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "bounds": { "$ref": "#/$defs/rect" },
        "work_area": { "$ref": "#/$defs/rect" },
        "scale_factor": { "type": "number", "exclusiveMinimum": 0 },
        "is_primary": { "type": "boolean" }
      }
    },
    "windowState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "display_id",
        "bounds",
        "z_order",
        "visible",
        "minimized",
        "maximized",
        "fullscreen",
        "active",
        "occluded",
        "eligible"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "display_id": { "$ref": "#/$defs/identifier" },
        "bounds": { "$ref": "#/$defs/rect" },
        "z_order": { "$ref": "#/$defs/nonNegativeSafeInteger" },
        "visible": { "type": "boolean" },
        "minimized": { "type": "boolean" },
        "maximized": { "type": "boolean" },
        "fullscreen": { "type": "boolean" },
        "active": { "type": "boolean" },
        "occluded": { "type": "boolean" },
        "eligible": { "type": "boolean" }
      }
    },
    "surfaceState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "display_id", "x1", "x2", "y", "enabled", "occluded"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "kind": { "enum": ["window_top", "work_area_floor"] },
        "display_id": { "$ref": "#/$defs/identifier" },
        "window_id": { "$ref": "#/$defs/identifier" },
        "x1": { "type": "number" },
        "x2": { "type": "number" },
        "y": { "type": "number" },
        "enabled": { "type": "boolean" },
        "occluded": { "type": "boolean" },
        "vx": { "type": "number" },
        "vy": { "type": "number" }
      }
    },
    "petState": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "x",
        "y",
        "width",
        "height",
        "foot_x",
        "foot_y",
        "vx",
        "vy",
        "facing",
        "behavior",
        "visible",
        "user_dragging"
      ],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "foot_x": { "type": "number" },
        "foot_y": { "type": "number" },
        "vx": { "type": "number" },
        "vy": { "type": "number" },
        "facing": { "enum": [-1, 1] },
        "behavior": { "$ref": "#/$defs/behavior" },
        "visible": { "type": "boolean" },
        "user_dragging": { "type": "boolean" },
        "surface_id": { "$ref": "#/$defs/identifier" }
      }
    },
    "cursorState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "left_down", "right_down", "middle_down", "over_pet"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "left_down": { "type": "boolean" },
        "right_down": { "type": "boolean" },
        "middle_down": { "type": "boolean" },
        "over_pet": { "type": "boolean" }
      }
    },
    "clickEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "button", "x", "y", "target", "timestamp_ms"],
      "properties": {
        "id": { "$ref": "#/$defs/identifier" },
        "button": { "enum": ["left", "right", "middle"] },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "target": { "enum": ["pet", "desktop", "window"] },
        "timestamp_ms": { "$ref": "#/$defs/nonNegativeSafeInteger" }
      }
    },
    "sceneState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fullscreen_active", "pet_allowed"],
      "properties": {
        "fullscreen_active": { "type": "boolean" },
        "pet_allowed": { "type": "boolean" },
        "suspend_reason": {
          "enum": ["fullscreen", "system_ui", "secure_desktop", "user_paused"]
        }
      }
    },
    "worldStatePayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "coordinate_space",
        "displays",
        "windows",
        "surfaces",
        "pet",
        "cursor",
        "clicks",
        "scene"
      ],
      "properties": {
        "session_id": { "$ref": "#/$defs/identifier" },
        "coordinate_space": { "const": "physical_px" },
        "displays": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/displayState" }
        },
        "windows": {
          "type": "array",
          "items": { "$ref": "#/$defs/windowState" }
        },
        "surfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/surfaceState" }
        },
        "pet": { "$ref": "#/$defs/petState" },
        "cursor": { "$ref": "#/$defs/cursorState" },
        "clicks": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/clickEvent" }
        },
        "scene": { "$ref": "#/$defs/sceneState" },
        "seed": { "type": "integer", "minimum": 0, "maximum": 4294967295 }
      }
    },
    "behavior": {
      "enum": ["idle", "walk", "jump", "click_reaction", "landing", "falling", "hidden", "fallback"]
    },
    "planTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface_id", "foot_x", "foot_y"],
      "properties": {
        "surface_id": { "$ref": "#/$defs/identifier" },
        "foot_x": { "type": "number" },
        "foot_y": { "type": "number" }
      }
    },
    "planPoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["t_ms", "dx", "dy", "vx", "vy", "facing", "lean", "squash", "bob", "expression"],
      "properties": {
        "t_ms": { "$ref": "#/$defs/nonNegativeSafeInteger" },
        "dx": { "type": "number", "minimum": -16384, "maximum": 16384 },
        "dy": { "type": "number", "minimum": -16384, "maximum": 16384 },
        "vx": { "type": "number", "minimum": -20000, "maximum": 20000 },
        "vy": { "type": "number", "minimum": -20000, "maximum": 20000 },
        "facing": { "enum": [-1, 1] },
        "lean": { "type": "number", "minimum": -1, "maximum": 1 },
        "squash": { "type": "number", "minimum": 0.5, "maximum": 1.5 },
        "bob": { "type": "number", "minimum": -48, "maximum": 48 },
        "expression": { "type": "string", "minLength": 1, "maxLength": 32 },
        "bone_rotations": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "type": "number", "minimum": -3.1416, "maximum": 3.1416 }
        },
        "facial_params": { "$ref": "#/$defs/facialParams" },
        "root_translation": { "$ref": "#/$defs/vec3" },
        "root_rotation": { "$ref": "#/$defs/quat" },
        "local_rotation_deltas": {
          "type": "array",
          "minItems": 1,
          "maxItems": 512,
          "items": { "$ref": "#/$defs/quat" }
        }
      },
      "allOf": [
        {
          "if": {
            "anyOf": [
              { "required": ["root_translation"] },
              { "required": ["root_rotation"] },
              { "required": ["local_rotation_deltas"] }
            ]
          },
          "then": {
            "required": [
              "root_translation",
              "root_rotation",
              "local_rotation_deltas"
            ],
            "not": { "required": ["bone_rotations"] }
          }
        },
        {
          "if": { "required": ["bone_rotations"] },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["root_translation"] },
                { "required": ["root_rotation"] },
                { "required": ["local_rotation_deltas"] }
              ]
            }
          }
        }
      ]
    },
    "facialParams": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "eye_scale": { "type": "number", "minimum": 0.5, "maximum": 1.5 },
        "eye_squint": { "type": "number", "minimum": 0, "maximum": 1 },
        "mouth_open": { "type": "number", "minimum": 0, "maximum": 1 },
        "ear_angle": { "type": "number", "minimum": -0.5, "maximum": 0.5 },
        "brow_tilt": { "type": "number", "minimum": -1, "maximum": 1 }
      }
    },
    "horizonPlanPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "plan_id",
        "based_on_seq",
        "behavior",
        "generated_at_ms",
        "valid_until_ms",
        "dt_ms",
        "confidence",
        "seed",
        "points"
      ],
      "properties": {
        "plan_id": { "$ref": "#/$defs/identifier" },
        "based_on_seq": { "$ref": "#/$defs/nonNegativeSafeInteger" },
        "behavior": { "$ref": "#/$defs/behavior" },
        "generated_at_ms": { "$ref": "#/$defs/nonNegativeSafeInteger" },
        "valid_until_ms": { "$ref": "#/$defs/nonNegativeSafeInteger" },
        "dt_ms": { "type": "integer", "minimum": 8, "maximum": 250 },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "seed": { "type": "integer", "minimum": 0, "maximum": 4294967295 },
        "target": { "$ref": "#/$defs/planTarget" },
        "points": {
          "type": "array",
          "minItems": 1,
          "maxItems": 512,
          "items": { "$ref": "#/$defs/planPoint" }
        }
      }
    },
    "cancelPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "requested_at_ms"],
      "properties": {
        "plan_id": { "$ref": "#/$defs/identifier" },
        "based_on_seq": { "$ref": "#/$defs/nonNegativeSafeInteger" },
        "reason": {
          "enum": ["user_drag", "topology_change", "safety", "newer_state", "shutdown"]
        },
        "requested_at_ms": { "$ref": "#/$defs/nonNegativeSafeInteger" }
      }
    },
    "pingPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nonce", "sent_at_ms"],
      "properties": {
        "nonce": { "$ref": "#/$defs/identifier" },
        "sent_at_ms": { "$ref": "#/$defs/nonNegativeSafeInteger" }
      }
    },
    "pongPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["nonce", "ping_sent_at_ms", "received_at_ms"],
      "properties": {
        "nonce": { "$ref": "#/$defs/identifier" },
        "ping_sent_at_ms": { "$ref": "#/$defs/nonNegativeSafeInteger" },
        "received_at_ms": { "$ref": "#/$defs/nonNegativeSafeInteger" }
      }
    },
    "numberMap": {
      "type": "object",
      "additionalProperties": { "type": "number" }
    },
    "stringMap": {
      "type": "object",
      "additionalProperties": { "type": "string", "maxLength": 128 }
    },
    "metricsPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "window_ms", "gauges", "counters"],
      "properties": {
        "source": { "enum": ["host", "generator"] },
        "window_ms": { "$ref": "#/$defs/nonNegativeSafeInteger" },
        "gauges": { "$ref": "#/$defs/numberMap" },
        "counters": { "$ref": "#/$defs/numberMap" },
        "labels": { "$ref": "#/$defs/stringMap" }
      }
    },
    "errorPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "recoverable"],
      "properties": {
        "code": { "$ref": "#/$defs/identifier" },
        "message": { "type": "string", "minLength": 1, "maxLength": 1024 },
        "recoverable": { "type": "boolean" },
        "related_seq": { "$ref": "#/$defs/nonNegativeSafeInteger" },
        "plan_id": { "$ref": "#/$defs/identifier" },
        "details": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer", "boolean", "null"]
          }
        }
      }
    }
  }
}
